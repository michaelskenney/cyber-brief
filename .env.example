# Secrets are now stored in macOS Keychain.
# To set up, run these commands (replace values with your actual credentials):
#
# security add-generic-password -s cyber-brief -a EXA_API_KEY -w "your-exa-key"
# security add-generic-password -s cyber-brief -a GMAIL_USER -w "you@gmail.com"
# security add-generic-password -s cyber-brief -a GMAIL_APP_PASSWORD -w "your-app-password"
# security add-generic-password -s cyber-brief -a NOTIFY_EMAIL -w "recipient@example.com"
#
# To verify a stored secret:
# security find-generic-password -s cyber-brief -a EXA_API_KEY -w
